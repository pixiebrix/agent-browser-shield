# Secrets — never commit
.env
.env.*
!.env.example
!env.sample
*.pem
*.key
credentials*.json
service-account*.json
*.p12

# Build output
extension/dist/
demo-site/dist/
output/

# Dependencies
node_modules/
.venv/
venv/
__pycache__/
*.py[cod]

# uv writes this whenever `uv run scripts/<x>.py` materializes a project lock,
# but the scripts use PEP 723 inline deps (per pyproject.toml) so there's
# nothing to pin at the workspace level.
uv.lock


{
  "name": "agent-browser-shield-extension",
  "version": "0.1.0-alpha.1",
  "private": true,
  "description": "Chromium MV3 extension prototype for agent-friendly browsing.",
  "license": "SEE LICENSE IN LICENSE",
  "author": "PixieBrix, Inc.",
  "homepage": "https://github.com/pixiebrix/agent-browser-shield#readme",
  "bugs": "https://github.com/pixiebrix/agent-browser-shield/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pixiebrix/agent-browser-shield.git",
    "directory": "extension"
  },
  "engines": {
    "node": ">=24",
    "bun": ">=1.1"
  },
  "packageManager": "bun@1.1.38",
  "type": "module",
  "scripts": {
    "build": "bun run build.ts",
    "watch": "bun run build.ts --watch",
    "package": "bun run ../scripts/package-extension.ts",
    "package:cws": "bun run ../scripts/package-extension.ts --strip-key -o ../output/extension-cws.zip",
    "fetch-easylist": "uv run --directory .. scripts/fetch_easylist.py",
    "build-site-data": "bun run scripts/build-site-data.ts",
    "build-injection-patterns": "bun run scripts/build-injection-patterns.ts",
    "build-icons": "bun run scripts/build-icons.ts",
    "clean": "rm -rf dist",
    "test": "jest",
    "check": "biome check . && eslint .",
    "check:fix": "biome check --write . && eslint . --fix",
    "format": "biome format --write .",
    "lint": "biome lint . && eslint .",
    "lint:eslint": "eslint .",
    "lint:eslint:fix": "eslint . --fix",
    "knip": "knip",
    "typecheck": "tsc --noEmit",
    "preflight": "bun run build-site-data && bun run build-injection-patterns && bun run check && bun run typecheck && bun run knip && bun run test"
  },
  "dependencies": {
    "abort-utils": "^3.0.0",
    "lodash": "^4.18.1",
    "nanoid": "^5.1.11",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "urlpattern-polyfill": "10.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@eslint/js": "10.0.1",
    "@resvg/resvg-js": "^2.6.2",
    "@types/bun": "^1.3.14",
    "@types/chrome": "^0.1.42",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/jsdom": "^28.0.3",
    "@types/lodash": "^4.17.24",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "eslint": "10.4.0",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unicorn": "64.0.0",
    "globals": "17.6.0",
    "jest": "^30",
    "jest-environment-jsdom": "^30",
    "js-yaml": "^4.1.0",
    "jsdom": "29.1.1",
    "knip": "^6.15.0",
    "ts-jest": "^29",
    "typescript": "^6.0.3",
    "typescript-eslint": "8.59.4",
    "zod": "^4.4.3"
  }
}

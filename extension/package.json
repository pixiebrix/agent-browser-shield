{
  "name": "agent-browser-shield-extension",
  "version": "0.1.0-alpha.1",
  "private": true,
  "description": "Chromium MV3 extension prototype for agent-friendly browsing.",
  "license": "SEE LICENSE IN LICENSE",
  "author": "PixieBrix, Inc.",
  "homepage": "https://github.com/pixiebrix/agent-browser-shield#readme",
  "bugs": "https://github.com/pixiebrix/agent-browser-shield/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pixiebrix/agent-browser-shield.git",
    "directory": "extension"
  },
  "engines": {
    "node": ">=24",
    "bun": ">=1.1"
  },
  "packageManager": "bun@1.1.38",
  "type": "module",
  "scripts": {
    "build": "bun run build.ts",
    "watch": "bun run build.ts --watch",
    "package": "bun run ../scripts/package-extension.ts",
    "package:cws": "bun run ../scripts/package-extension.ts --strip-key -o ../output/extension-cws.zip",
    "fetch-easylist": "uv run --directory .. scripts/fetch_easylist.py",
    "fetch-justdeleteme": "uv run --directory .. scripts/fetch_justdeleteme.py",
    "build-site-data": "bun run scripts/build-site-data.ts",
    "build-injection-patterns": "bun run scripts/build-injection-patterns.ts",
    "build-icons": "bun run scripts/build-icons.ts",
    "clean": "rm -rf dist",
    "test": "jest",
    "test:coverage": "jest --coverage --coverageReporters=text-summary",
    "check": "biome check . && eslint . && stylelint \"src/**/*.{css,html}\"",
    "check:fix": "biome check --write . && eslint . --fix && stylelint \"src/**/*.{css,html}\" --fix",
    "format": "biome format --write .",
    "lint": "biome lint . && eslint . && stylelint \"src/**/*.{css,html}\"",
    "lint:eslint": "eslint .",
    "lint:eslint:fix": "eslint . --fix",
    "lint:stylelint": "stylelint \"src/**/*.{css,html}\"",
    "lint:stylelint:fix": "stylelint \"src/**/*.{css,html}\" --fix",
    "knip": "knip",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.test.json --noEmit",
    "preflight": "bun run build-site-data && bun run build-injection-patterns && bun run check && bun run typecheck && bun run knip && bun run test:coverage"
  },
  "dependencies": {
    "abort-utils": "^3.0.0",
    "file-saver": "^2.0.5",
    "idb": "^8.0.3",
    "lodash": "^4.18.1",
    "nanoid": "^5.1.14",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tldts": "^7.4.3",
    "urlpattern-polyfill": "10.1.0",
    "webext-messenger": "^0.35.0",
    "webext-storage": "^3.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@cfworker/json-schema": "^4.1.1",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
    "@eslint/js": "10.0.1",
    "@resvg/resvg-js": "^2.6.2",
    "@types/bun": "^1.3.14",
    "@types/chrome": "^0.1.43",
    "@types/file-saver": "^2.0.7",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash": "^4.17.24",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.0",
    "eslint": "10.5.0",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unicorn": "68.0.0",
    "fake-indexeddb": "^6.2.5",
    "fast-check": "^4.8.0",
    "globals": "17.6.0",
    "jest": "^30",
    "jest-environment-jsdom": "^30",
    "jest-webextension-mock": "^4.1.1",
    "js-yaml": "^4.2.0",
    "knip": "^6.17.1",
    "postcss-html": "^1.8.1",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "ts-jest": "^29",
    "type-fest": "^5.7.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "8.61.1",
    "zod": "^4.4.3"
  }
}

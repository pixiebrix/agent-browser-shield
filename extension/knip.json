{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "scripts/*.ts",
    "src/background.ts",
    "src/content.ts",
    "src/popup.tsx",
    "src/options.tsx",
    "src/webdriver-probe.ts",
    "src/checkout-checkbox-defense.ts",
    "eslint-rules/index.js"
  ],
  "project": ["src/**/*.{ts,tsx}", "scripts/**/*.ts", "eslint-rules/**/*.js"],
  "ignoreExportsUsedInFile": true,
  "ignoreBinaries": ["uv"]
}

{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "scripts/*.ts",
    "src/background.ts",
    "src/content.ts",
    "src/popup.tsx",
    "src/options.tsx",
    "eslint-rules/index.js"
  ],
  "project": ["src/**/*.{ts,tsx}", "scripts/**/*.ts", "eslint-rules/**/*.js"],
  "ignore": ["src/**/*.generated.ts"],
  "ignoreExportsUsedInFile": true,
  "ignoreBinaries": ["uv"],
  "ignoreDependencies": ["jsdom", "@types/jsdom"]
}

{
  "name": "agent-browser-shield-demo-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Mock e-commerce SPA exercising the threats that agent-browser-shield defends against.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint:eslint": "eslint .",
    "lint:stylelint": "stylelint \"src/**/*.css\"",
    "lint:stylelint:fix": "stylelint \"src/**/*.css\" --fix",
    "check": "biome check . && eslint . && stylelint \"src/**/*.css\""
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.5.0",
    "eslint-plugin-unicorn": "^68.0.0",
    "globals": "^17.6.0",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-tailwindcss": "^1.0.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16"
  }
}

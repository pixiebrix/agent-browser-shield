# Copy to .env and fill in. Loaded by scripts/agent_task.py from the repo root.

# Browserbase API key. Create one at https://www.browserbase.com/settings.
# Used to upload the extension and start sessions.
BROWSERBASE_API_KEY=

# Browserbase project ID (UUID) the sessions are billed against.
# Find it under Settings → Projects.
BROWSERBASE_PROJECT_ID=

# --- Agent model key (OPTIONAL when using Browserbase Model Gateway) ---
#
# Two modes:
#
# 1) Model Gateway (recommended for sweeping models)
#    Leave MODEL_API_KEY blank. Stagehand will route the cloud agent's LLM
#    calls through Browserbase, billed to your BROWSERBASE_API_KEY at the
#    upstream provider's market rate (no markup). To switch models, change
#    the `model:` field in benchmark/scenarios*.yaml — no new accounts or
#    keys needed.
#    Supported providers via Gateway: OpenAI, Anthropic, Google.
#    Docs: https://docs.browserbase.com/platform/model-gateway/overview
#
# 2) Direct provider key
#    Set MODEL_API_KEY to your OpenAI / Anthropic / Google key. The provider
#    is inferred from the model prefix (e.g. openai/…, anthropic/…). Useful
#    if you need a model Gateway doesn't carry, or want to use credits on a
#    provider account.
MODEL_API_KEY=

# --- Judge keys ---
#
# scripts/_judge.py calls the judge model directly (not via Stagehand), so
# Model Gateway does NOT cover it. With MODEL_API_KEY blank you must set
# whichever provider key matches `defaults.judge_model` in your scenarios
# file (default judge is openai/gpt-4o-mini, so OPENAI_API_KEY is enough).
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

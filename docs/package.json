  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Astro Starlight documentation site for agent-browser-shield.",
  "packageManager": "bun@1.3.0",
  "engines": {
    "node": ">=24",
    "bun": ">=1.3"
  },
  "scripts": {
